# WebNovel Knowledge Base Configuration
# Copy this file to .env and fill in your values

# Data directory
WEBNOVEL_KB_DATA=./webnovel_data

# LLM API Configuration (compatible with OpenAI-compatible APIs)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://your-embedding-api-endpoint
LLM_CHAT_BASE_URL=https://your-chat-api-endpoint

# Model names
LLM_EMBEDDING_MODEL=your_embedding_model
LLM_RERANK_MODEL=your_rerank_model
LLM_CHAT_MODEL=your_chat_model

# Embedding dimensions (must match your model's output)
LLM_EMBEDDING_DIMENSIONS=4096

# MCP Server Configuration
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_TRANSPORT=sse
