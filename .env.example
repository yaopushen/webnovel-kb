# WebNovel Knowledge Base 环境变量配置

# === LLM API 配置 ===
# 支持 OpenAI 兼容 API（如 OpenAI、DeepSeek、智谱等）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_BASE_URL=https://api.openai.com/v1

# === 模型配置 ===
LLM_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LLM_EMBEDDING_DIMENSIONS=512
LLM_RERANK_MODEL=
LLM_CHAT_MODEL=gpt-3.5-turbo

# === 数据存储路径 ===
WEBNOVEL_KB_DATA=./data

# === MCP 服务器配置 ===
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8765
